      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python -m enact.cli.code_hook post"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python -m enact.cli.code_hook post"
          }
        ]
